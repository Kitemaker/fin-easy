# Auth0 v4 — Regular Web App
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_SECRET=use-openssl-rand-hex-32
AUTH0_BASE_URL=http://localhost:3000

# Auth0 Management API (M2M app — for Token Vault)
AUTH0_MGMT_CLIENT_ID=your_m2m_client_id
AUTH0_MGMT_CLIENT_SECRET=your_m2m_client_secret

# AI
OPENAI_API_KEY=your_openai_api_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo tokens for mock financial services
DEMO_CHECKING_TOKEN=demo_checking_token_abc123
DEMO_SAVINGS_TOKEN=demo_savings_token_def456
DEMO_INVESTMENTS_TOKEN=demo_investments_token_ghi789
DEMO_BILLS_TOKEN=demo_bills_token_jkl012
